#include <stdio.h>

int main() {
    int attendance;
    int presentCount = 0;

    for(int i = 1; i <= 30; i++) {
        printf("Enter attendance for student %d (1 = Present, 0 = Absent): ", i);
        scanf("%d", &attendance);

        if(attendance == 1) {
            presentCount++;
        }
    }

    printf("Total students present: %d\n", presentCount);

    return 0;
}
