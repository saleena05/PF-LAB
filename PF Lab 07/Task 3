#include <stdio.h>

int main()
{
    int pass[10], fail[10];
    int i = 0, j = 0;
    int mark;
    float avgPass = 0, avgFail = 0;

    printf("Enter marks (-1 to exit):\n");

    while(1)
    {
        scanf("%d", &mark);

        if(mark == -1)
            break;

        if(mark >= 5 && mark <= 10 && i < 10)
        {
            pass[i] = mark;
            avgPass += mark;
            i++;
        }
        else if(mark >= 0 && mark < 5 && j < 10)
        {
            fail[j] = mark;
            avgFail += mark;
            j++;
        }
    }

    printf("Pass marks:\n");
    for(int k = 0; k < i; k++)
        printf("%d ", pass[k]);

    printf("\nFail marks:\n");
    for(int k = 0; k < j; k++)
        printf("%d ", fail[k]);

    if(i > 0)
        printf("\nAverage pass marks = %.2f", avgPass/i);

    if(j > 0)
        printf("\nAverage fail marks = %.2f", avgFail/j);

    return 0;
}
