#include <stdio.h>

int main()
{
    float temp[7][3];
    int i,j;
    float highest;
    float avg,sum;

    printf("Enter temperature for 7 days (Morning Afternoon Night):\n");

    for(i=0;i<7;i++)
    {
        for(j=0;j<3;j++)
        {
            scanf("%f",&temp[i][j]);
        }
    }

    highest = temp[0][0];

    for(i=0;i<7;i++)
    {
        for(j=0;j<3;j++)
        {
            if(temp[i][j] > highest)
                highest = temp[i][j];
        }
    }

    printf("Highest temperature of week = %.2f\n", highest);

    for(i=0;i<7;i++)
    {
        sum = 0;

        for(j=0;j<3;j++)
        {
            sum = sum + temp[i][j];
        }

        avg = sum / 3;

        printf("Average temperature of Day %d = %.2f\n", i+1, avg);
    }

    return 0;
}
